---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBlogPosts } from "../utils/blog.js";

const posts = await getBlogPosts();
const latestPosts = posts.slice(0, 3);
---

<BaseLayout
	title="Home - Personal Website"
	description="Welcome to my personal website with blog"
>
	<section class="hero">
		<div class="container">
			<div class="hero-content">
				<h1>Welcome to My Personal Website</h1>
				<p>
					A place where I share my thoughts, projects, and
					experiences.
				</p>
				<div class="hero-actions">
					<a href="/about" class="btn">Learn More About Me</a>
					<a href="/blog" class="btn btn-secondary">Read My Blog</a>
				</div>
			</div>
		</div>
	</section>

	<section class="featured">
		<div class="container">
			<h2>Latest from the Blog</h2>
			<div class="latest-posts">
				{
					latestPosts.length > 0 ? (
						latestPosts.map((post) => (
							<div class="post-card">
								<h2>
									<a href={`/blog/${post.slug}`}>
										{post.title}
									</a>
								</h2>
								<div class="post-meta">
									{post.date} • {post.category}
								</div>
								<p class="post-excerpt">{post.excerpt}</p>
								<a
									href={`/blog/${post.slug}`}
									class="read-more"
								>
									Read more →
								</a>
							</div>
						))
					) : (
						<p>No blog posts yet. Check back soon!</p>
					)
				}
			</div>
		</div>
	</section>
</BaseLayout>
