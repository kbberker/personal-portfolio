---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getBlogPostBySlug, blogPosts } from "../../utils/blog.js";

export async function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const processedPost = await getBlogPostBySlug(post.slug);
---

<BaseLayout title={`${post.title} — Blog`} description={post.excerpt}>
  <article class="wrap post">
    <a class="back" href="/blog">← Back to blog</a>
    <div class="date">{post.date} · {post.category}</div>
    <h1>{post.title}</h1>
    {processedPost && <div class="body" set:html={processedPost.htmlContent} />}
  </article>
</BaseLayout>

<style>
  .post {
    padding-block: var(--s7);
    max-width: 720px;
  }

  .back {
    display: inline-block;
    font-size: 14px;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    margin-bottom: var(--s6);
  }

  .back:hover {
    text-decoration: underline;
  }

  .date {
    font-size: 13px;
    color: var(--muted);
    font-weight: 600;
    margin-bottom: var(--s3);
  }

  h1 {
    font-weight: 800;
    font-size: 38px;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 var(--s6);
  }

  /* Rendered markdown */
  .body :global(h1),
  .body :global(h2),
  .body :global(h3) {
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin: var(--s7) 0 var(--s4);
  }

  .body :global(h2) {
    font-size: 26px;
  }

  .body :global(h3) {
    font-size: 20px;
  }

  .body :global(p),
  .body :global(li) {
    font-size: 17px;
    line-height: 1.7;
    color: var(--muted);
    font-weight: 450;
  }

  .body :global(p) {
    margin: 0 0 var(--s5);
  }

  .body :global(ul),
  .body :global(ol) {
    margin: 0 0 var(--s5);
    padding-left: var(--s5);
  }

  .body :global(li) {
    margin-bottom: var(--s2);
  }

  .body :global(strong) {
    color: var(--fg);
    font-weight: 700;
  }

  .body :global(a) {
    color: var(--accent);
    font-weight: 600;
  }

  .body :global(code) {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 14px;
    background: var(--accent-soft);
    color: var(--accent);
    padding: 1px 6px;
    border-radius: 5px;
  }

  .body :global(pre) {
    background: #0f141b;
    color: #cdd6e2;
    border-radius: 12px;
    padding: 20px;
    overflow-x: auto;
    margin: 0 0 var(--s5);
  }

  .body :global(pre code) {
    background: transparent;
    color: inherit;
    padding: 0;
    font-size: 13px;
    line-height: 1.7;
  }

  .body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: var(--s4);
    margin: 0 0 var(--s5);
    color: var(--muted);
    font-style: italic;
  }

  .body :global(hr) {
    border: 0;
    height: 1px;
    background: var(--line);
    margin: var(--s7) 0;
  }

  @media (min-width: 720px) {
    .post {
      padding-block: var(--s8);
    }

    h1 {
      font-size: 52px;
    }
  }
</style>
