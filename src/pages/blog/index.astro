---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getBlogPosts } from "../../utils/blog.js";

const posts = await getBlogPosts();
---

<BaseLayout
  title="Blog — Kenan Berker"
  description="Notes on frontend engineering, performance, and accessibility."
>
  <div class="wrap page">
    <div class="label">Blog</div>
    <h1>Writing</h1>
    <p class="lede">Notes on frontend engineering, performance, and accessibility.</p>

    <div class="posts">
      {
        posts.length > 0 ? (
          posts.map((post) => (
            <article class="post">
              <span class="date">
                {post.date} · {post.category}
              </span>
              <a class="post-title" href={`/blog/${post.slug}`}>
                {post.title}
              </a>
              <p class="post-desc">{post.excerpt}</p>
            </article>
          ))
        ) : (
          <p class="empty">No posts yet — check back soon.</p>
        )
      }
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding-block: var(--s7);
  }

  .label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--s4);
  }

  h1 {
    font-weight: 800;
    font-size: 38px;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .lede {
    font-size: 17px;
    line-height: 1.6;
    color: var(--muted);
    font-weight: 500;
    margin-top: var(--s3);
  }

  .posts {
    margin-top: var(--s7);
  }

  .post {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: var(--s5) 0;
    border-top: 1px solid var(--line);
  }

  .date {
    font-size: 13px;
    color: var(--muted);
    font-weight: 600;
  }

  .post-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--fg);
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .post-title:hover {
    color: var(--accent);
  }

  .post-desc {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.6;
    font-weight: 450;
  }

  .empty {
    color: var(--muted);
    font-weight: 500;
  }

  @media (min-width: 720px) {
    .page {
      padding-block: var(--s8);
    }

    h1 {
      font-size: 56px;
    }
  }
</style>
