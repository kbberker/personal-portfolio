---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Me - Personal Website" description="Learn more about me, my background, skills, and experience">
	<section class="about-hero">
		<div class="container">
			<h1>About Me</h1>
			<p>Get to know me better</p>
		</div>
	</section>

	<section class="about-content">
		<div class="container">
			<div class="about-grid">
				<div class="about-text">
					<h2>My Story</h2>
					<p>
						Hi! I'm [Your Name], a passionate [your profession/field] based in [your location].
						I love creating things, solving problems, and sharing knowledge with others.
					</p>
					<p>
						With [X years] of experience in [your field], I've had the opportunity to work on
						exciting projects and collaborate with amazing teams. I'm always eager to learn
						new technologies and tackle challenging problems.
					</p>
				</div>

				<div class="skills-section">
					<h2>Skills & Technologies</h2>
					<div class="skills-grid">
						<div class="skill-category">
							<h3>Programming Languages</h3>
							<ul>
								<li>JavaScript</li>
								<li>Python</li>
								<li>TypeScript</li>
								<li>HTML/CSS</li>
							</ul>
						</div>
						<div class="skill-category">
							<h3>Frameworks & Tools</h3>
							<ul>
								<li>React</li>
								<li>Node.js</li>
								<li>Git</li>
								<li>Docker</li>
							</ul>
						</div>
						<div class="skill-category">
							<h3>Soft Skills</h3>
							<ul>
								<li>Problem Solving</li>
								<li>Team Collaboration</li>
								<li>Communication</li>
								<li>Project Management</li>
							</ul>
						</div>
					</div>
				</div>

				<div class="experience-section">
					<h2>Experience</h2>
					<div class="experience-item">
						<h3>Senior Developer</h3>
						<p class="company">Company Name</p>
						<p class="period">2022 - Present</p>
						<p>
							Led development of web applications, mentored junior developers,
							and implemented best practices for code quality and performance.
						</p>
					</div>
					<div class="experience-item">
						<h3>Full Stack Developer</h3>
						<p class="company">Previous Company</p>
						<p class="period">2020 - 2022</p>
						<p>
							Developed and maintained multiple client projects using modern
							web technologies and agile methodologies.
						</p>
					</div>
				</div>

				<div class="contact-section">
					<h2>Get In Touch</h2>
					<div class="contact-info">
						<p><strong>Email:</strong> your.email@example.com</p>
						<p><strong>LinkedIn:</strong> <a href="https://linkedin.com/in/yourprofile">linkedin.com/in/yourprofile</a></p>
						<p><strong>GitHub:</strong> <a href="https://github.com/yourusername">github.com/yourusername</a></p>
						<p><strong>Location:</strong> Your City, Country</p>
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>